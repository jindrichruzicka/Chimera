{
    // Per-package build for @chimera-engine/simulation (issue #759, Appendix C.3/§C.4).
    //
    // Emits the published artifact under ./dist (JS + .d.ts) consumed via the
    // package's `exports` map. Composite so it can be wired as a `tsc --build`
    // project reference (the acyclic DAG deferred from F57/#756 is now possible
    // because simulation absorbed shared and has zero workspace dependencies).
    //
    // Actual test files (`*.test.ts`, `__tests__/`) and lint fixtures are
    // excluded. Cross-package test doubles (`__test-support__`) ARE built: other
    // workspace packages import them (e.g. the shared SaveRepository contract
    // suite) via `@chimera-engine/simulation/.../__test-support__/*.js`, so under the
    // build-before-consume model they must exist in `dist/`. This package is
    // `private` and never published, so shipping vitest-coupled test suites in
    // its in-tree `dist/` is intentional, not a leak.
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "noEmit": false,
        "rootDir": ".",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "tsBuildInfoFile": "./dist/.tsbuildinfo"
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "**/__tests__/**"]
}
