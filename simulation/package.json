{
    "name": "@chimera-engine/simulation",
    "version": "1.0.0-rc.1",
    "description": "Deterministic, host-authoritative game-simulation core for the Chimera engine.",
    "license": "MIT",
    "author": "Jindrich Ruzicka <ing.jindrich.ruzicka@gmail.com>",
    "homepage": "https://github.com/jindrichruzicka/Chimera#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jindrichruzicka/Chimera.git",
        "directory": "simulation"
    },
    "bugs": "https://github.com/jindrichruzicka/Chimera/issues",
    "private": false,
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./contracts": {
            "types": "./dist/contracts/index.d.ts",
            "default": "./dist/contracts/index.js"
        },
        "./engine": {
            "types": "./dist/engine/index.d.ts",
            "default": "./dist/engine/index.js"
        },
        "./scene": {
            "types": "./dist/scene/index.d.ts",
            "default": "./dist/scene/index.js"
        },
        "./content": {
            "types": "./dist/content/index.d.ts",
            "default": "./dist/content/index.js"
        },
        "./persistence": {
            "types": "./dist/persistence/index.d.ts",
            "default": "./dist/persistence/index.js"
        },
        "./profile": {
            "types": "./dist/profile/index.d.ts",
            "default": "./dist/profile/index.js"
        },
        "./projection": {
            "types": "./dist/projection/index.d.ts",
            "default": "./dist/projection/index.js"
        },
        "./replay": {
            "types": "./dist/replay/index.d.ts",
            "default": "./dist/replay/index.js"
        },
        "./settings": {
            "types": "./dist/settings/index.d.ts",
            "default": "./dist/settings/index.js"
        },
        "./debug": {
            "types": "./dist/debug/index.d.ts",
            "default": "./dist/debug/index.js"
        },
        "./host": {
            "types": "./dist/host/index.d.ts",
            "default": "./dist/host/index.js"
        },
        "./*.js": {
            "types": "./dist/*.d.ts",
            "default": "./dist/*.js"
        }
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "!dist/**/__test-support__/**"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run --config ../vitest.config.mts --dir .",
        "lint": "eslint ."
    },
    "dependencies": {
        "zod": "^4.3.6"
    }
}
