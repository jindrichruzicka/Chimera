{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Vitest: run all tests",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/vitest",
            "runtimeArgs": ["run"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Vitest: debug all tests",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/vitest",
            "runtimeArgs": ["run", "--no-file-parallelism"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Vitest: debug current test file",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/vitest",
            "runtimeArgs": ["run", "--no-file-parallelism", "${relativeFile}"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "ESLint: lint workspace",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/eslint",
            "runtimeArgs": ["."],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "ESLint: lint workspace (fix)",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/eslint",
            "runtimeArgs": [".", "--fix"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "ESLint: lint current file",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/eslint",
            "runtimeArgs": ["${relativeFile}"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Playwright: run all tests",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/playwright",
            "runtimeArgs": ["test", "--config", "e2e/playwright.config.ts"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Playwright: debug all tests",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/playwright",
            "runtimeArgs": ["test", "--config", "e2e/playwright.config.ts", "--debug"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "autoAttachChildProcesses": true,
            "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
            "smartStep": true
        }
    ]
}
