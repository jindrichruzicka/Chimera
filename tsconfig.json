{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022"],
        "types": ["node"],
        "strict": true,
        "noImplicitAny": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noPropertyAccessFromIndexSignature": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "baseUrl": "."
    },
    // `simulation/**`, `ai/**`, `networking/**`, and `electron/**` are NOT compiled
    // by this program: each is a built package (see simulation/tsconfig.json,
    // ai/tsconfig.json, networking/tsconfig.json, electron/tsconfig.json) and
    // consumers here resolve it through its `exports` map onto `<pkg>/dist`. Their
    // own source + tests are type-checked by their own
    // `tsc --noEmit -p <pkg>/tsconfig.json`. Only simulation's ambient global env
    // declarations are pulled in directly (the Node programs need NODE_ENV /
    // CHIMERA_DEBUG augmentations; the renderer program declares NODE_ENV itself).
    "include": [
        // apps/tactics/**/*.ts is co-included (as games/**/*.ts was) so the tactics
        // SOURCE is type-checked within this one flat program. This is also the SOLE
        // type-checker of the app's Electron composition root
        // (apps/tactics/electron/main.ts — the in-tree game injection seam #778,
        // relocated here from the top-level app/ in F63/#783): it consumes the
        // @chimera/electron host through the package exports map (onto electron/dist)
        // and resolves @chimera/tactics onto SOURCE here, so it is type-checked here
        // rather than by electron/tsconfig.json or the tactics composite build (which
        // excludes electron/** to keep the layer-2 library off @chimera/electron).
        // Only .ts is included — this program carries no DOM/jsx/react libs, so the
        // screens/shell .tsx are type-checked separately by
        // `tsc --noEmit -p apps/tactics/tsconfig.json`. The package's dist/ is built
        // by tsc -b but not yet consumed (F64 flips consumers to dist and excludes
        // apps/tactics from this program, mirroring electron).
        "apps/tactics/**/*.ts",
        "renderer/**/*.ts",
        "tools/**/*.ts",
        "e2e/**/*.ts",
        "simulation/foundation/env.d.ts",
        "simulation/foundation/env-node.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        "out",
        "**/out/**",
        "simulation/engine/__tests__/fixtures/**",
        "ai/engine/__tests__/fixtures/**",
        "networking/__tests__/fixtures/**",
        // apps/tactics SOURCE is type-checked here (its .ts are co-included so the
        // composition root apps/tactics/electron/main.ts resolves @chimera/tactics),
        // but its tsc -b dist/ emit must be excluded or the emitted .d.ts
        // double-declare against the source.
        "apps/tactics/dist/**",
        // electron/ is compiled exclusively by electron/tsconfig.json (#777): its
        // built package is consumed here through the @chimera/electron exports map
        // onto electron/dist. Excluding the source prevents double-compilation and
        // a source/dist type-identity split.
        "electron/**",
        // renderer/ is compiled exclusively by renderer/tsconfig.json (Next.js plugin + JSX).
        // Excluding it here prevents double-compilation and plugin conflicts.
        // Cross-package type checks run via renderer/tsconfig.json in CI.
        "renderer/**"
    ]
}
