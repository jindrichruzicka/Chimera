{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2022"],
        "types": ["node"],
        "strict": true,
        "noImplicitAny": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noPropertyAccessFromIndexSignature": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "baseUrl": "."
    },
    // `simulation/**`, `ai/**`, `networking/**`, and `electron/**` are NOT compiled
    // by this program: each is a built package (see simulation/tsconfig.json,
    // ai/tsconfig.json, networking/tsconfig.json, electron/tsconfig.json) and
    // consumers here resolve it through its `exports` map onto `<pkg>/dist`. Their
    // own source + tests are type-checked by their own
    // `tsc --noEmit -p <pkg>/tsconfig.json`. Only simulation's ambient global env
    // declarations are pulled in directly (the Node programs need NODE_ENV /
    // CHIMERA_DEBUG augmentations; the renderer program declares NODE_ENV itself).
    "include": [
        // apps/*/**/*.ts co-includes every consumer app's SOURCE (as games/**/*.ts
        // did for the single game) so each app is type-checked within this one flat
        // program. This is also the SOLE type-checker of each app's Electron
        // composition root (apps/<game>/electron/main.ts — the in-tree game injection
        // seam #778, relocated here from the top-level app/ in F63/#783): it consumes
        // the @chimera/electron host through the package exports map (onto
        // electron/dist) and resolves the app's own @chimera/<game> onto SOURCE here,
        // so it is type-checked here rather than by electron/tsconfig.json or the app
        // composite build (which excludes electron/** to keep the layer-3 app's
        // library half off @chimera/electron). Only .ts is included — this program
        // carries no DOM/jsx/react libs, so the screens/shell .tsx are type-checked
        // separately by `tsc --noEmit -p apps/<game>/tsconfig.json`. Each app's dist/
        // is built by tsc -b and excluded below (it is consumed via the package
        // exports map, not re-type-checked here).
        "apps/*/**/*.ts",
        "renderer/**/*.ts",
        "tools/**/*.ts",
        "simulation/foundation/env.d.ts",
        "simulation/foundation/env-node.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        "out",
        "**/out/**",
        "simulation/engine/__tests__/fixtures/**",
        "ai/engine/__tests__/fixtures/**",
        "networking/__tests__/fixtures/**",
        // Each app's SOURCE is type-checked here (its .ts are co-included so the
        // composition root apps/<game>/electron/main.ts resolves @chimera/<game>),
        // but its tsc -b dist/ emit must be excluded or the emitted .d.ts
        // double-declare against the source.
        "apps/*/dist/**",
        // apps/<game>/renderer/** is the game's renderer composition root + its own
        // Next app (#784, F65): register.ts/loaders.ts and the app/** route re-exports
        // import the game's screens/shell .tsx and the @chimera/renderer package, so —
        // like the screens/shell .tsx — they need DOM/jsx/react libs this .ts-only flat
        // program deliberately omits. They are type-checked with jsx by
        // `tsc --noEmit -p apps/<game>/tsconfig.json` and by the app composite build
        // (the app references renderer, a lower layer — no back-edge), so excluding them
        // here avoids a TS6142 ("--jsx is not set") on the .tsx imports.
        "apps/*/renderer/**",
        // electron/ is compiled exclusively by electron/tsconfig.json (#777): its
        // built package is consumed here through the @chimera/electron exports map
        // onto electron/dist. Excluding the source prevents double-compilation and
        // a source/dist type-identity split.
        "electron/**",
        // renderer/ is compiled exclusively by renderer/tsconfig.json (Next.js plugin + JSX).
        // Excluding it here prevents double-compilation and plugin conflicts.
        // Cross-package type checks run via renderer/tsconfig.json in CI.
        "renderer/**"
    ]
}
