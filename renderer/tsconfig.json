{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "jsx": "preserve",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "react", "react-dom"],
        "allowJs": true,
        "incremental": true,
        "plugins": [{ "name": "next" }]
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "../electron/preload/api.ts",
        "../simulation/foundation/env.d.ts",
        "next-env.d.ts",
        ".next/types/**/*.ts"
    ],
    "exclude": ["node_modules", "out", ".next", "__tests__/fixtures/**"]
}
