{
    "name": "chimera",
    "version": "0.0.0",
    "private": true,
    "description": "Host-authoritative, multiplatform multiplayer game engine built on Electron + React Three Fiber.",
    "license": "UNLICENSED",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "main": "electron/main/index.js",
    "scripts": {
        "typecheck": "tsc --noEmit && tsc --noEmit -p renderer",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "coverage": "vitest run --coverage",
        "build:renderer": "next build renderer"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^22.10.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^2.1.9",
        "electron": "^33.2.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.2",
        "next": "^15.5.15",
        "prettier": "^3.3.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.59.0",
        "vite-tsconfig-paths": "^4.3.2",
        "vitest": "^2.1.8"
    },
    "dependencies": {
        "zod": "^4.3.6"
    }
}
