{
    "name": "chimera",
    "version": "0.8.0",
    "private": true,
    "description": "Host-authoritative, multiplatform multiplayer game engine built on Electron + React Three Fiber.",
    "license": "UNLICENSED",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=20.0.0"
    },
    "main": "app/main.js",
    "scripts": {
        "build:packages": "tsc -b tsconfig.build.json && tsx tools/copy-renderer-css.ts",
        "typecheck": "pnpm build:packages && tsc --noEmit && tsc --noEmit -p simulation/tsconfig.json && tsc --noEmit -p ai/tsconfig.json && tsc --noEmit -p networking/tsconfig.json && tsc --noEmit -p renderer/tsconfig.json && tsc --noEmit -p electron/tsconfig.json && tsc --noEmit -p apps/tactics/tsconfig.json",
        "test": "pnpm build:packages && pnpm -r test && vitest run --dir tools && vitest run --dir e2e",
        "test:watch": "pnpm build:packages && vitest",
        "test:e2e": "pnpm build:packages && playwright test --config=e2e/playwright.config.ts --project=electron-e2e",
        "test:perf": "pnpm build:packages && cross-env NODE_OPTIONS=--expose-gc CHIMERA_PERF_STRICT=1 vitest run apps/tactics/__tests__/ActionPipelinePerf.bench.test.ts",
        "validate:assets": "pnpm build:packages && tsx tools/validate-assets.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "pnpm build:packages && pnpm -r lint && eslint app tools e2e eslint.config.mjs vitest.config.mts",
        "lint:fix": "eslint . --fix",
        "coverage": "pnpm build:packages && vitest run --coverage",
        "build:renderer": "pnpm build:packages && next build renderer",
        "fetch:fonts": "pnpm build:packages && tsx tools/fetch-google-fonts.ts",
        "dev:mp": "pnpm build:packages && cross-env CHIMERA_DEV_HARNESS=1 tsx tools/dev-multiplayer.ts"
    },
    "devDependencies": {
        "@eslint/css": "^1.2.0",
        "@eslint/js": "^9.39.4",
        "@next/eslint-plugin-next": "^16.2.6",
        "@playwright/test": "^1.59.1",
        "@react-three/test-renderer": "^9.1.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.10.0",
        "@types/pino": "^7.0.5",
        "@types/pngjs": "^6.0.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.1",
        "@vitest/browser": "^4.1.5",
        "@vitest/coverage-v8": "^3.2.4",
        "chokidar": "^5.0.0",
        "cross-env": "^10.1.0",
        "electron": "^33.2.0",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.2",
        "fast-check": "^4.7.0",
        "jsdom": "^29.0.2",
        "next": "^15.5.15",
        "pngjs": "^7.0.0",
        "prettier": "^3.3.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "tsx": "^4.21.0",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.59.0",
        "vite-tsconfig-paths": "^4.3.2",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "@chimera/ai": "workspace:*",
        "@chimera/electron": "workspace:*",
        "@chimera/networking": "workspace:*",
        "@chimera/renderer": "workspace:*",
        "@chimera/simulation": "workspace:*",
        "@chimera/tactics": "workspace:*",
        "@react-three/fiber": "^9.6.1",
        "@types/ws": "^8.18.1",
        "pino": "^10.3.1",
        "three": "^0.184.0",
        "ws": "^8.20.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    }
}
