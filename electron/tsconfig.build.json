{
    // Per-package build for @chimera-engine/electron (issue #777, F62 — Appendix C.3/§3).
    // Follows the split-tsconfig dist pattern established on the leaf in
    // simulation/tsconfig.build.json (#759) and copied by ai (#764), networking
    // (#768) and renderer (#773): composite emit under ./dist (JS + .d.ts + maps)
    // consumed via the package `exports` map, test files excluded.
    //
    // Unlike renderer/tsconfig.build.json (which SCOPES `include` to the public
    // component-barrel closure because the renderer package is also the Next app
    // and most of it cannot compile standalone), electron is plain Node TypeScript
    // that compiles whole — so `include` is the package-wide `**/*.ts` the leaf
    // packages use. The exports map (not the build) is what curates the public
    // surface: main-process internals are emitted to dist but are NOT reachable as
    // package subpaths (Invariant #5).
    //
    // electron sits at the TOP of the engine graph (layer 2) and references all four
    // engine packages it depends on — simulation, ai, networking and renderer — so
    // `tsc --build` orders the build after them (Invariant #1). This stays acyclic:
    // electron imports nothing from renderer at runtime, and renderer's only edge to
    // electron is the chat barrel's type-only `@chimera-engine/electron/preload/api-types`
    // back-edge, which renderer/tsconfig.build.json resolves onto electron SOURCE via
    // a `paths` alias rather than a project reference — so there is no renderer →
    // electron reference and thus no TS6202 cycle (the build order is simulation →
    // ai/networking/renderer → electron).
    //
    // `@chimera-engine/electron` names no game: every game-specific seam now arrives by
    // runtime injection through `MainGameContribution` (mainGameRegistry in T2/#778;
    // content schemas + lobby setup in #788/#789), so the package no longer imports
    // `@chimera-engine/tactics` at all — there is no game reference, composite or
    // node_modules-symlink, to resolve. The consumer app composition root
    // (apps/tactics/electron/main.ts) is the sole place that names a game.
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "noEmit": false,
        "rootDir": ".",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "tsBuildInfoFile": "./dist/.tsbuildinfo"
    },
    "references": [
        { "path": "../simulation/tsconfig.build.json" },
        { "path": "../ai/tsconfig.build.json" },
        { "path": "../networking/tsconfig.build.json" },
        { "path": "../renderer/tsconfig.build.json" }
    ],
    // Ambient ProcessEnv declarations pulled in explicitly — see the matching
    // note in electron/tsconfig.json: this project's `include` is
    // package-relative, and without them `noPropertyAccessFromIndexSignature`
    // rejects the dot-access debug gate that esbuild's `define` must fold.
    "include": [
        "**/*.ts",
        "../simulation/foundation/env.d.ts",
        "../simulation/foundation/env-node.d.ts"
    ],
    "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "**/__tests__/**"]
}
