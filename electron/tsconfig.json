{
    // Type-check / editor / ESLint project for @chimera-engine/electron (issue #777).
    // This is the config typescript-eslint's project service and the root
    // `typecheck` script use for the package: it covers ALL of electron/ — source,
    // `*.test.ts`, and test-support — on source. The published artifact is emitted
    // separately by tsconfig.build.json (which excludes test files). noEmit —
    // purely a verification/editor project.
    //
    // No path aliases are needed: every intra-package import is relative, so
    // `@chimera-engine/electron/*` never appears inside electron/ and the package's own
    // exports map never redirects a same-package import to dist.
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "noEmit": true
    },
    // The two ambient ProcessEnv declarations are pulled in explicitly: this
    // project's `include` is package-relative, so it would otherwise miss them
    // and `noPropertyAccessFromIndexSignature` would reject the dot-access debug
    // gate in main/index.ts — the very shape esbuild's `define` needs to fold
    // (§4.12, Invariant #27). `env-node.d.ts`'s own header already names the
    // Electron program as in scope; only the renderer program must exclude it.
    "include": [
        "**/*.ts",
        "../simulation/foundation/env.d.ts",
        "../simulation/foundation/env-node.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "main/__tests__/fixtures/**",
        "preload/__tests__/fixtures/**"
    ]
}
