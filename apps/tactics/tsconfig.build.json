{
    // Composite `tsc -b` build for the @chimera-engine/tactics consumer app (F63 #782).
    // Graduates tactics into the root solution config's dependency-ordered build
    // graph (tsconfig.build.json), following the split-tsconfig dist pattern of the
    // engine packages (simulation #759 / ai #764 / renderer #773) — composite emit
    // under ./dist (JS + .d.ts + maps), test files excluded.
    //
    // JSX compiles to runnable JS via the React 19 automatic runtime ("react-jsx"),
    // UNLIKE the editor config tsconfig.json which keeps jsx:"preserve". lib/types
    // mirror renderer/tsconfig.build.json so the screens/shell .tsx + R3F scene
    // compile without the Next plugin; css-modules.d.ts supplies the *.module.css
    // ambient.
    //
    // NOTE (F63 staging): this dist/ is currently UNCONSUMED. Consumers still resolve
    // @chimera-engine/tactics from SOURCE via the vitest resolver plugin + Next webpack alias;
    // the emit exists only to make tactics a node in the `tsc -b` graph. F64 adds the
    // package `exports` map and flips consumers onto dist/.
    //
    // LAYER 3 (#791): apps/tactics is the top-of-graph consumer APP — it depends on
    // everything and nothing depends on it (since #784/#788/#789, no engine package
    // statically imports a game; they reach it only by runtime registration). It
    // therefore sits ABOVE @chimera-engine/electron (layer 2), not beside it. References
    // mirror its composite workspace deps (simulation, ai, renderer, electron), so
    // `tsc --build` orders the graph (Invariant #1, tools/tsconfig-build-graph.test.ts).
    // The @chimera-engine/electron reference exists to mirror the package dep that the app's
    // Electron composition root (electron/main.ts) introduces; that composition root
    // is EXCLUDED from this composite's emit (it is bundled by `build:app` /
    // the app-owned electron/build-main.ts and type-checked by the root flat
    // `tsc --noEmit`), because a runnable Electron main must be a single bundled
    // file, not a tsc composite output.
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "noEmit": false,
        "rootDir": ".",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "tsBuildInfoFile": "./dist/.tsbuildinfo",
        "allowArbitraryExtensions": true,
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "react", "react-dom"]
    },
    "references": [
        { "path": "../../simulation/tsconfig.build.json" },
        { "path": "../../ai/tsconfig.build.json" },
        { "path": "../../renderer/tsconfig.build.json" },
        { "path": "../../electron/tsconfig.build.json" }
    ],
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": [
        "node_modules",
        "dist",
        "out",
        // The Electron composition root (electron/main.ts) imports @chimera-engine/electron
        // and belongs to the standalone app, not the @chimera-engine/tactics library — keep
        // it out of the layer-2 composite build (see header note; F63/#783).
        "electron/**",
        // The Playwright e2e suite (relocated here in F63/#785) is test infrastructure,
        // not library source — its non-test .ts (page objects, fixtures, global-setup.ts,
        // playwright.config.ts) must not be compiled into dist/. The *.test/*.spec
        // patterns below only cover its co-located unit/spec files.
        "e2e/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/__tests__/**"
    ]
}
