{
    // Playwright-runner resolution shim ONLY (referenced by playwright.config.ts
    // `tsconfig`). F57 (#752) removed the `@chimera-engine/*` `paths` from the root
    // tsconfig so production `tsc` resolves through real workspace deps. But the
    // Playwright test transform loads electron main/preload source (which imports
    // `@chimera-engine/*`) and resolves bare specifiers ONLY via tsconfig paths — it has
    // no webpack/vite-style alias hook like next.config.ts / vitest.config.mts /
    // global-setup.ts. These paths restore resolution for the runner without
    // reintroducing an alias into any production/typecheck tsconfig (root +
    // renderer stay alias-free; `pnpm typecheck` does not use this file).
    // Transitional: F63 (#785) relocated the suite here (apps/tactics/e2e/), but the
    // shim stays because `@chimera-engine/tactics` is still consumed from SOURCE
    // (`apps/tactics/*`) until F64 flips it onto its package `exports` map; removable
    // once that lands. Paths below are baseUrl-relative (repo root), so unchanged.
    "extends": "../../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": "../../..",
        "paths": {
            "@chimera-engine/simulation/*": ["simulation/dist/*"],
            "@chimera-engine/ai/*": ["ai/dist/*"],
            "@chimera-engine/networking": ["networking/dist/index.d.ts"],
            "@chimera-engine/networking/*": ["networking/dist/*"],
            "@chimera-engine/renderer/*": ["renderer/dist/*"],
            "@chimera-engine/electron/*": ["electron/dist/*"],
            "@chimera-engine/tactics/*": ["apps/tactics/*"]
        }
    }
}
